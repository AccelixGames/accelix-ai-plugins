{
  "description": "Security review hook — checks for team/project/personal information leaks before modifying plugin files",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_info_leak.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
